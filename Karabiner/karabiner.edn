 {
  :templates {
             :alfred "osascript -e 'tell application id \"com.runningwithcrayons.Alfred\" to run trigger \"%s\" in workflow \"%s\" with argument \"%s\"'"
             :km "osascript -e 'tell application \"Keyboard Maestro Engine\" to do script \"%s\"'"
             :open "open \"%s\""
             :app "open -a \"%s\""
             }

  ; max ms between trigger key and second key for a simlayer to fire.
  ; 250 is goku's default; lower it (e.g. 200) if layers misfire while typing fast.
  :simlayer-threshold 250

  :layers {
           :caps-mode {:key :caps_lock :alone {:key :escape}} ; hold caps = text layer, tap caps = escape
           :tab-mode {:key :tab :alone {:key :tab}} ; hold tab = symbol layer, tap tab = tab
           }
  :simlayers {
              :q-mode {:key :q} ; hold q + key = open apps
              :w-mode {:key :w} ; hold w + key = window management (Rectangle)
              :f-mode {:key :f} ; hold f + key = right-hand numpad
              :period-mode {:key :period} ; hold . + key = dev symbols (Norwegian layout)
              :x-mode {:key :x} ; hold x + key = system: volume, brightness, screenshots, lock
              }
  :applications {
                 :spotify ["com.spotify.client"]
                 :chrome ["com.google.Chrome"]
                 :vscode ["com.microsoft.VSCode"]
                 :cursor ["com.cursor.app"]
                 }

  :main

  [{:des "main profile"
    :rules [;; [:left_command  :left_command nil  {:alone :!Cd}]
            ;; [{:key :spacebar :modi :left_shift} [:spacebar :0 :spacebar]]
            ]}
   {:des "capslock layer"
    :rules [; hold caps = navigation, selection, and editing; tap caps = escape
            :caps-mode

            ; SELECTION (shift + key). These must come before the ##-rules that
            ; share the same keys, otherwise the ##-rules (optional any modifier)
            ; match first and shadow them.
            [:!Sh :!Sleft_arrow] ; select left
            [:!Sj :!Sdown_arrow] ; select down
            [:!Sk :!Sup_arrow] ; select up
            [:!Sl :!Sright_arrow] ; select right
            [:!Sw :!OSright_arrow] ; select word forward
            [:!Sb :!OSleft_arrow] ; select word backward
            [:!Sv [:!CSleft_arrow :!CSright_arrow]] ; select entire line
            [:!Sa :!CSup_arrow] ; select to top of document
            [:!Ss :!CSdown_arrow] ; select to end of document
            [:!Sg :!Cdown_arrow] ; bottom of document (vim G)
            [:!Sd [:!CSleft_arrow :delete_or_backspace]] ; delete to start of line
            [:!St :!TStab] ; previous tab (ctrl+shift+tab)

            ; NAVIGATION
            ; Tier 1: character/line movement (## = extra modifiers pass through)
            [:##h :##left_arrow]
            [:##j :##down_arrow]
            [:##k :##up_arrow]
            [:##l :##right_arrow]
            ; Tier 2: word movement
            [:##b :!Oleft_arrow] ; back one word
            [:##w :!Oright_arrow] ; forward one word
            ; Tier 3: page jumping
            [:##a :page_up]
            [:##s :page_down]
            ; Tier 4: line and document jumps
            [:##e :!Cright_arrow] ; end of line
            [:##0 :!Cleft_arrow] ; start of line (vim 0)
            [:g :!Cup_arrow] ; top of document (vim gg)
            [:t :!Ttab] ; next tab (ctrl+tab)

            ; EDITING
            [:##spacebar :return_or_enter] ; space is enter
            [:##d [:!Cright_arrow :!Cdelete_or_backspace :delete_or_backspace]] ; delete whole line
            [:##f [:!CSright_arrow :delete_or_backspace]] ; delete to end of line
            [:##x :delete_or_backspace] ; delete character
            [:##i :!Odelete_or_backspace] ; delete word
            [:##u :!Cz] ; undo
            [:##r :!CSz] ; redo
            [:##y :!Cc] ; copy
            [:##o :!Cv] ; paste
            [:##p :!CSv] ; paste from clipboard history

            ; NUMBERS 1-9 ARE SHIFT + NUMBER (0 is start of line, see above)
            [:1 :!S1]
            [:2 :!S2]
            [:3 :!S3]
            [:4 :!S4]
            [:5 :!S5]
            [:6 :!S6]
            [:7 :!S7]
            [:8 :!S8]
            [:9 :!S9]
            ]}
   {:des "tab layer"
    :rules [; hold tab = symbols and Keyboard Maestro macros; tap tab = tab
            :tab-mode
            ; SYMBOL CLUSTER (Norwegian layout: ⌥8=[ ⌥9=] ⇧⌥8={ ⇧⌥9=} ⇧8=( ⇧9=))
            [:h :!O8] ; [
            [:l :!O9] ; ]
            [:j :!SO8] ; {
            [:k :!SO9] ; }
            [:n :!S8] ; (
            [:m :!S9] ; )

            ; KEYBOARD MAESTRO MACROS (via their KM hotkeys)
            [:i :!OSCr] ; add clipboard to inbox note
            [:o :!OSCt] ; run tomatobar

            ; CODE DIGRAPHS (typed as two-key sequences; Norwegian layout:
            ; - is the :slash key, > is shift+<>-key — see dot-layer note on :non_us_backslash)
            [:y [:slash :!Snon_us_backslash]] ; ->
            [:u [:!S0 :!Snon_us_backslash]] ; =>
            [:p [:!S1 :!S0]] ; !=
            ]}
   {:des "wkey (windows)"
    :rules [; hold w + key = Rectangle window management
            :w-mode
            [:m :!OTreturn_or_enter] ; maximize
            [:h :!OTleft_arrow] ; left half
            [:l :!OTright_arrow] ; right half
            [:j :!OTdown_arrow] ; bottom half
            [:k :!OTup_arrow] ; top half
            [:u :!OTd] ; first third
            [:i :!OTf] ; center third
            [:o :!OTg] ; last third
            [:y :!OTe] ; first two thirds
            [:p :!OTt] ; last two thirds
            [:c :!OTc] ; center window
            ]}
   {:des "qkey (apps)"
    :rules [; hold q + key = open app directly (no Keyboard Maestro dependency)
            :q-mode
            [:k [:app "Helium"]]
            [:j [:app "Cursor"]]
            [:l [:app "Ghostty"]]
            [:f [:app "Finder"]]
            [:s [:app "Spotify"]]
            [:n [:app "Obsidian"]]
            [:r [:app "ChatGPT"]]
            [:m [:app "Messages"]]
            [:e [:app "Claude"]]
            [:w [:app "Slack"]]
            ]}
   {:des "fkey (numpad)"
    :rules [; hold f + right hand = numpad, laid out like the real thing
            ; 7 8 9   -> u i o
            ; 4 5 6   -> j k l
            ; 1 2 3   -> m , .
            ; 0 and decimal comma on n and h
            :f-mode
            [:u :7]
            [:i :8]
            [:o :9]
            [:j :4]
            [:k :5]
            [:l :6]
            [:m :1]
            [:comma :2]
            [:period :3]
            [:n :0]
            [:h :comma] ; decimal separator
            ]}
   {:des "dot key (dev symbols)"
    :rules [; hold . + key = programming symbols that are awkward on the Norwegian
            ; layout; complements the tab layer's bracket cluster.
            ; NOTE: on some Apple ISO keyboards the <> key reports as
            ; :grave_accent_and_tilde instead of :non_us_backslash — check
            ; Karabiner EventViewer and swap if < and > come out wrong.
            :period-mode
            [:j :!S7] ; / (shift+7)
            [:k :!SO7] ; \ (shift+option+7)
            [:l :!O7] ; | (option+7)
            [:h :!S1] ; !
            [:u :non_us_backslash] ; <
            [:i :!Snon_us_backslash] ; >
            [:o :!S0] ; =
            [:p :!Shyphen] ; ? (shift on the +/? key)
            [:m :!S4] ; $ (Apple Norwegian: shift+4)
            [:y [:!Sequal_sign :spacebar]] ; ` (dead key shift+´, then space)
            [:n [:!Oclose_bracket :spacebar]] ; ~ (dead key option+¨, then space)
            ]}
   {:des "xkey (system)"
    :rules [; hold x + key = system controls: volume, brightness, screenshots,
            ; lock screen, dark mode
            :x-mode
            [:j :volume_decrement]
            [:k :volume_increment]
            [:m :mute]
            [:h :display_brightness_decrement]
            [:l :display_brightness_increment]
            [:u :!TCq] ; lock screen (ctrl+cmd+q)
            [:p :!CST4] ; screenshot area -> clipboard (cmd+ctrl+shift+4)
            [:o :!CS4] ; screenshot area -> file (cmd+shift+4)
            [:i :!CS5] ; screenshot/recording options (cmd+shift+5)
            [:d "osascript -e 'tell application \"System Events\" to tell appearance preferences to set dark mode to not dark mode'"] ; toggle dark mode
            ]}
   {:des "Spotify controls"
    :rules [; Media controls for Spotify
            [:##play_or_pause "osascript -e 'tell application \"Spotify\" to playpause'"]
            [:##fast_forward "osascript -e 'tell application \"Spotify\" to next track'"]
            [:##rewind "osascript -e 'tell application \"Spotify\" to previous track'"]

            ; Additional Spotify controls with fn + media keys
            [:!Fplay_or_pause "osascript -e 'tell application \"Spotify\" to set shuffling to not shuffling'"] ; fn + play = toggle shuffle
            [:!Ffast_forward "osascript -e 'tell application \"Spotify\" to set repeating to not repeating'"] ; fn + next = toggle repeat

            ; Volume controls for Spotify
            [:!Svolume_increment "osascript -e 'tell application \"Spotify\" to set sound volume to (sound volume + 10)'"] ; shift + vol up
            [:!Svolume_decrement "osascript -e 'tell application \"Spotify\" to set sound volume to (sound volume - 10)'"] ; shift + vol down
            ]}
   {:des "right command key" ; right command key for app specific commands
    :rules [
            [:right_command :!Cl :spotify]
            [:right_command :!Cl :chrome]
            [:right_command :!Cp :vscode]
            [:right_command :!Cp :cursor]
            ]}
   {:des "hyper key"
    :rules [; hold right command = hyper (⌘⌃⌥⇧), tap = right command.
            ; The app-specific rules above win in Spotify/Chrome/VSCode/Cursor.
            ; Hyper is a conflict-free hotkey namespace for Hammerspoon and
            ; Keyboard Maestro bindings (see hammerspoon/init.lua).
            [:right_command :!QWEright_shift nil {:alone :right_command}]
            ]}
   {:des "Quit application by command + Q only when pressing twice"
    :rules [[:!Cq
             [:!Cq ["command-q" 0]]
             ["command-q" 1]]
            [:!Cq
             ["command-q" 1]
             nil
             {:delayed {:invoked ["command-q" 0] :canceled ["command-q" 0]}}]]}
   ]
  }
;; :key | means key
;; !  | means mandatory
;; #  | means optional
;; C  | left_command
;; T  | left_control
;; O  | left_option
;; S  | left_shift
;; F  | fn
;; Q  | right_command
;; W  | right_control
;; E  | right_option
;; R  | right_shift
;; !! | mandatory command + control + optional + shift (hyper)
;; ## | optional any
